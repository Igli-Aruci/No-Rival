var output = { rewards: [] };
var sku = "COP";

// Verifichiamo che l'account sia in bozza
if (ikContext.account && ikContext.account.isDraft === true) {
    
    // 1. Quanti coperti abbiamo impostato ora?
    var targetCount = ikContext.account.clientCount || 0;
    
    // 2. Quanti SKU "COP" sono già presenti nel sistema?
    var existingRewards = ikContext.account.rewards || [];
    var currentCount = 0;
    for (var i = 0; i < existingRewards.length; i++) {
        if (existingRewards[i].sku === sku) {
            currentCount++;
        }
    }

    // 3. Calcoliamo la differenza
    if (targetCount > currentCount) {
        // Se mancano, aggiungiamo
        var toAdd = targetCount - currentCount;
        for (var a = 0; a < toAdd; a++) {
            output.rewards.push({ type: "ADD", sku: sku });
        }
    } 
else if (targetCount < currentCount) {
        var toRemove = currentCount - targetCount;
        // Filtriamo solo i premi "COP" che hanno un ID
        var itemsToRemove = existingRewards.filter(function(r) { return r.sku === sku; });
        
        for (var r = 0; r < toRemove; r++) {
            output.rewards.push({ 
                type: "REMOVE", 
                id: itemsToRemove[r].id // Usiamo l'ID interno del sistema
            });
        }
    }
// Restituisce il comando alla piattaforma
JSON.stringify(output);
