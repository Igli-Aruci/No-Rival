var output = { rewards: [] };
var sku = "COP";

if (ikContext.account && ikContext.account.isDraft === true) {
    
    // 1. Quanti coperti dovrebbero esserci (Target)
    var targetCount = ikContext.account.clientCount || 0;
    
    // 2. Recuperiamo i premi esistenti e filtriamo solo quelli con lo SKU "COP"
    var existingRewards = ikContext.account.rewards || [];
    var copItems = [];
    
    for (var i = 0; i < existingRewards.length; i++) {
        if (existingRewards[i].sku === sku) {
            copItems.push(existingRewards[i]);
        }
    }
    
    var currentCount = copItems.length;

    // 3. LOGICA DI SINCRONIZZAZIONE
    if (targetCount > currentCount) {
        // AZIONE: AGGIUNGI (se mancano)
        var toAdd = targetCount - currentCount;
        for (var a = 0; a < toAdd; a++) {
            output.rewards.push({
                type: "ADD",
                sku: sku
            });
        }
    } 
    else if (targetCount < currentCount) {
        // AZIONE: RIMUOVI (se sono troppi)
        var toRemove = currentCount - targetCount;
        for (var r = 0; r < toRemove; r++) {
            // Usiamo l'ID specifico della riga esistente per eliminarla
            // Se "REMOVE" non dovesse andare, prova a cambiare in "DELETE"
            output.rewards.push({
                type: "REMOVE",
                id: copItems[r].id 
            });
        }
    }
}

// Trasforma l'oggetto finale in stringa JSON per il sistema
JSON.stringify(output);
